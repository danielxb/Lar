# Timezone
TZ=Australia/Sydney

# Server port (host-side)
PORT=7777

# Weather location (Open-Meteo, no API key needed)
WEATHER_LAT=-33.87
WEATHER_LON=151.21

# Flask secret key (change in production)
SECRET_KEY=change-me-in-production

# Worker name for work log / invoices
WORKER_NAME=worker

# Database path (default: data/lar.db)
# DB_PATH=/app/data/lar.db

# Start with demo data loaded (0=off, 1=on)
# DEMO_MODE=0
